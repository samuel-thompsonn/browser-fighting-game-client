# Local development defaults (loaded by `npm start`, never by production builds).
# Mock auth removes the need for AWS / Cognito SSO just to run the client.
# To use real Cognito locally instead, create `.env.development.local` with
# REACT_APP_MOCK_AUTH=false (and a real REACT_APP_API_URL).
REACT_APP_API_URL=http://localhost:3001
REACT_APP_MOCK_AUTH=true